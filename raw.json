:{\"usa\":\"Created a Wish List, \\u003Ca href='https:\\u002F\\u002Fsecure.newegg.com\\u002Fwishlist\\u002Fpd\\u002F${WishListNumber}' class='link-underline' title='${Title}' target='_blank'\\u003E${Title}\\u003C\\u002Fa\\u003E\",\"can\":\"Created a Wish List, \\u003Ca href='https:\\u002F\\u002Fsecure.newegg.ca\\u002Fwishlist\\u002Fpd\\u002F${WishListNumber}' class='link-underline' title='${Title}' target='_blank'\\u003E${Title}\\u003C\\u002Fa\\u003E\",\"global\":\"Created a Wish List, \\u003Ca href='https:\\u002F\\u002Fsecure.newegg.com\\u002Fglobal\\u002F${alpha2}-en\\u002Fwishlist\\u002Fpd\\u002F${WishListNumber}' class='link-underline' title='${Title}' target='_blank'\\u003E${Title}\\u003C\\u002Fa\\u003E\"},\"trackingValue\":\"header-notification-wishlist\"}],\"officialAccountConfigList\":[{\"bizSubjectType\":\"OFFICIALNEWS\",\"accountDetail\":[{\"countryList\":[\"default\"],\"displayName\":\"Newegg\",\"avatar\":\"Newegg_Notification@2x.png\"},{\"countryList\":[\"USA\"],\"displayName\":\"Newegg\",\"avatar\":\"Newegg_Notification@2x.png\"},{\"countryList\":[\"CAN\"],\"displayName\":\"Newegg\",\"avatar\":\"Newegg_Notification@2x.png\"}]},{\"bizSubjectType\":\"RETENTIONEMAILPRICEDROP\",\"accountDetail\":[{\"countryList\":[\"default\"],\"displayName\":\"Price Drop\",\"avatar\":\"Newegg_Notification@2x.png\"},{\"countryList\":[\"USA\"],\"displayName\":\"Price Drop\",\"avatar\":\"Newegg_Notification@2x.png\"},{\"countryList\":[\"CAN\"],\"displayName\":\"Price Drop\",\"avatar\":\"Newegg_Notification@2x.png\"}]}],\"notificationV2\":{\"enableV2Percentage\":100,\"notificationsRequestPageSize\":10,\"enableGuest\":true},\"browserNotification\":{\"reminderIntervalMins\":30,\"localStorageTimeoutMins\":1440,\"content\":{\"title\":\"Hi there!\",\"icon\":\"https:\\u002F\\u002Fc1.neweggimages.com\\u002FWebResource\\u002FThemes\\u002FNest\\u002Ficons\\u002FTips_Avatar_Circle.png\",\"body\":\"You have unread messages, please check on Newegg.com.\",\"redirectHref\":\"https:\\u002F\\u002Fwww.newegg.com?cm_sp=Browser_Notification-_-From_WNS&IsExpandNotification=true\"}},\"notificationFeedBack\":{\"dislikeReason\":[{\"type\":1,\"content\":\"Expired promotion\"},{\"type\":2,\"content\":\"Felt spammy\"},{\"type\":3,\"content\":\"Inaccurate\"},{\"type\":4,\"content\":\"Not interested\"},{\"type\":5,\"content\":\"Privacy concerns\"},{\"type\":6,\"content\":\"I don\u2019t want these notifications\"},{\"type\":9,\"content\":\"Other reason\"}],\"dislikeModalTextareMaxLength\":1000,\"selectReasonMax\":3},\"defultNotificationMoreAction\":[{\"type\":\"DeleteSingle\",\"text\":\"Delete\"}]},\"aiLabBiz\":{\"AiMode\":{\"EnableCountries\":[\"USA\"],\"Enable\":true,\"TargetPercent\":100,\"ShowSM\":true,\"Pin\":{\"EnableCountries\":[\"USA\"],\"Enable\":true,\"PinSessionExpiresDays\":7},\"GeoJson\":[{\"@context\":\"https:\\u002F\\u002Fschema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Newegg AI Mode\",\"alternateName\":\"Celeste\",\"applicationCategory\":\"ShoppingApplication\",\"operatingSystem\":\"Web\",\"description\":\"Newegg AI Mode is a conversational AI shopping assistant that reimagines product discovery beyond traditional search and filters. It supports natural language product search, side-by-side product comparison, detailed product consultation, and direct in-conversation checkout.\",\"url\":\"https:\\u002F\\u002Fwww.newegg.com\\u002Fai\",\"datePublished\":\"2026-06-16\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Newegg\",\"url\":\"https:\\u002F\\u002Fwww.newegg.com\",\"tickerSymbol\":\"NEGG\",\"sameAs\":[\"https:\\u002F\\u002Fen.wikipedia.org\\u002Fwiki\\u002FNewegg\",\"https:\\u002F\\u002Fwww.linkedin.com\\u002Fcompany\\u002Fnewegg\"]},\"featureList\":[\"Natural language product search\",\"Product comparison\",\"Product consultation\",\"Direct in-conversation checkout\"]},{\"@context\":\"https:\\u002F\\u002Fschema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What Does Newegg AI Mode Do?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Newegg AI Mode is a conversational AI shopping assistant built directly into Newegg.com. Instead of searching and filtering through pages of results, you can describe what you need in natural language, compare items side-by-side, ask detailed questions about a product, and check out directly within the conversation, all without leaving the page.\"}},{\"@type\":\"Question\",\"name\":\"Why Is Newegg Building an AI Shopping Experience?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"As AI tools like ChatGPT have reshaped what people expect from digital interactions, shoppers increasingly want intuitive, conversational experiences instead of traditional search and filters. Newegg AI Mode is Newegg's move to modernize its shopping experience with a ChatGPT-style conversational mode, applying Newegg's product data and shopping expertise to become an early leader in AI-driven conversational commerce.\"}},{\"@type\":\"Question\",\"name\":\"Why Use Newegg AI Mode?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Traditional shopping often means searching, filtering, and comparing across multiple pages before finding the right product, and that effort can lead to friction or an abandoned cart. AI Mode reduces that friction: describe what you need in plain language and get instant, trustworthy answers, confident comparisons, and a direct path to checkout, all in the same conversation.\"}},{\"@type\":\"Question\",\"name\":\"What Can You Explore with AI Mode?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"With AI Mode you can find products using natural language (for example, \\\"a quiet 2TB SSD under $150\\\"), compare two or more products side-by-side, ask detailed questions to get product consultation, and pay for your order directly within the conversation.\"}},{\"@type\":\"Question\",\"name\":\"Who Can Benefit from Newegg AI Mode?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"AI Mode is built for everyone: shoppers who aren't sure exactly what to search for, buyers comparing multiple options before deciding, anyone with detailed product questions, and shoppers who want a faster, more direct path from question to checkout.\"}},{\"@type\":\"Question\",\"name\":\"How Does AI Mode Complement Traditional Search?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"AI Mode doesn't replace traditional search, it complements it for different needs. Keyword search and filters work well when you already know exactly what you're looking for, like a specific model number. As shoppers increasingly expect more intuitive, conversational experiences, similar to what they've come to expect from tools like ChatGPT, AI Mode is better suited for open-ended questions, side-by-side comparisons, and detailed product consultation, and it lets you check out directly in the same conversation. Many users move between both, starting a conversation with AI Mode and refining results with search filters, or vice versa.\"}},{\"@type\":\"Question\",\"name\":\"What is Newegg AI Mode?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Newegg AI Mode is an AI-powered conversational shopping assistant on Newegg.com. It helps you find products using natural language, compare products side-by-side, answer detailed product questions, and complete checkout directly in the conversation.\"}},{\"@type\":\"Question\",\"name\":\"When did Newegg AI Mode launch?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Newegg AI Mode launched publicly on June 16, 2026. The floating panel (Float mode) became available on June 24, 2026. Pin mode is targeted for mid-July 2026.\"}},{\"@type\":\"Question\",\"name\":\"What types of questions can I ask Newegg AI Mode?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You can ask AI Mode to find products in natural language (for example, \\\"a budget GPU for 1080p gaming\\\"), compare two or more products side-by-side, ask detailed product consultation questions, and complete your purchase directly within the conversation.\"}}]}]}},\"domainTable\":\"(\\u0014[G\\u0001\\u000e\\u0000\\u0013GIM7E\\u0004\\u0004\\u0012\\u0004G_M\\u001dO\\u001e\\u0000\\u001c\\r\\u0016QU\\\"[Q\\u0015\\u001a\\u0013GIM\\u0017E\\u0004\\u0004\\u0012\\u0004K\\u0010\\u0000\\u0014\\u0002_C\\u001c\\u0007GIM7E\\u0004\\u0004\\u0012\\u0004:&\\u003C8\\u0002_C\\u0006\\u0016\\u0007QU\\u0002\\u0002\\u0004\\u0016\\u0002A_Q\\u0018\\u000eWQMW\\u0010\\u0016\\u001fMC\\u0002\\u0000\\u0004\\u0016\\u0016\\u0017\\u0016MU\\u0002\\u001e\\u000e\\u0017\\n\\t\\u0016\\u001c\\nLQ[W\\u0010\\u0000\\u0010\\u001a\\u000bE]\\fW\\u001e\\u0018_\\u0014[T\\u001c\\u0011WYG\\u001d\\n\\u000eE\\u0014\\u0006[\\u0000\\u0004QC[I\\u0017COA+\\u0016\\u0018\\u001cG\\u0014\\u003E6\\\"+QC[S\\u0006\\u0003WY\\u001eQ\\u0018\\u000eWQ[W\\u0014\\u0012\\u0004MU\\u0002\\u0000\\u0012\\u0019A_Q\\u001c\\u001cC\\u0006\\u0013\\u0010AIQ\\u0002\\u0016B\\u001a\\r\\u0010\\u0010\\u0016\\u001fMC\\u0002\\u0000\\u0004\\u0016\\u0016\\u0017\\u0016A\\u0014\\u0002\\u000e\\u001cY\\u0018G\\u0007\\u0000\\t\\u0002IC\\u0018M\\u000b\\u0016\\u0018\\u001cG\\u0014O\\u0016\\f\\bQC[I\\u0017COA(,!\\u001cW\\u0016\\u0006\\u0012\\u003C0 .[\\fQ\\u0012\\u0000\\u0001GI\\u0014[S\\u0000\\rWYG\\u0000\\n\\u001aU\\u0001\\u0004W\\u001e\\u0018.\\u0012U[Q\\u0006\\u0007\\f\\u0010\\u0003MC\\u000241 AIQ\\u000b\\u0016M\\u0012\\b\\u001b\\u0010GI4\\u0002\\u0002\\u0007\\u000e\\u0005A_Q\\u0005\\fS\\u0007\\u0006\\u0005\\u0016K\\u0010\\u0000\\u0014\\u0002_C\\u001c\\u0007GIM\\u003Ep&CYA\\u0016\\u0006\\r[\\u001a\\bC\\u0002\\u0014\\u0012QU[W\\u0004\\u0016WOG\\u0000\\u001c\\u0015\\u0002IC\\u0006\\u0006\\u0006\\u0006\\u001d\\u001c\\u0002\\u000e\\u001c(\\u001eI\\bM\\u001eR\\u001c\\u0014\\u0005A_Q:;\\u00121CYA\\u0001\\u001c\\u0002\\u0018I\\u001d\\u0012WY\\u003E\\bM\\rO\\u0003COA\\u000b\\u0016\\u0018\\u001cG\\u0014\\u0003\\u0000\\u0010\\f\\u001d\\n\\nS]\\u0002\\u001a\\u000eG_M\\u0010DQ[W!W1MU\\u0002\\u0000\\u0014\\u0017A_\\bM\\u000eW\\u0004COA\\u0012\\u0004\\u0018[\\fQ\\u0012